FROM python:3.9-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for caching
COPY apps/engine/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the entire engine app
# Note: We assume the build context is the monorepo root, or we copy specifically.
# To keep it simple and independent, let's assume this Dockerfile is run from monorepo root context
# OR we copy just what we need. 
# Let's try to make it self-contained relative to the build context defined in docker-compose.
COPY apps/engine /app/apps/engine

# Set python path to allow imports from apps.engine...
ENV PYTHONPATH=/app

# Expose port
EXPOSE 8000

# Run the application
CMD ["uvicorn", "apps.engine.main:app", "--host", "0.0.0.0", "--port", "8000"]
