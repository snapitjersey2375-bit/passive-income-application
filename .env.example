# Database (PostgreSQL recommended for Prod, SQLite for Dev)
DATABASE_URL=postgresql://user:password@localhost:5432/nexusflow
# Or for local dev: sqlite:///./nexusflow.db

# Backend API URL (for Next.js server-side fetches)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Security (JWT Secret, etc.)
SECRET_KEY=change_this_to_a_secure_random_string

# External Services
OPENAI_API_KEY=sk-proj-...
TIKTOK_ACCESS_TOKEN=
SHOPIFY_ACCESS_TOKEN=
